{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "treatConfigHintsAsErrors": true,
  "workspaces": {
    ".": {
      "includeEntryExports": true,
      "entry": ["test/setup.ts", "vitest.config.mts"]
    },
    "ts": {
      "ignoreBinaries": ["oxfmt", "vitest"],
      "ignoreDependencies": ["oxlint-plugin-complexity"],
      "ignore": ["test/rules/fixtures/**/*.ts"],
      "entry": [
        "src/index.ts",
        "src/rules/plugin.ts",
        "bench/run-all.ts",
        "bench/rfd-compare.ts",
        "bench/rfd-perf.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "bench/**/*.ts", "test/**/*.ts"]
    }
  }
}
