{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["oxlint.workspace.config.mjs"],
  "oxlint": {
    "config": ["oxlint.config.mjs"]
  },
  "treatConfigHintsAsErrors": true,
  "workspaces": {
    ".": {
      "includeEntryExports": true,
      "entry": [
        "scripts/release-plan.mjs",
        "test/**/*.test.mjs",
        "test/setup.ts",
        "vitest.config.mts"
      ],
      "project": ["scripts/**/*.mjs", "test/**/*.mjs", "test/**/*.ts"]
    },
    "ts": {
      "ignoreBinaries": ["oxfmt", "vitest"],
      "ignoreDependencies": [
        "@oxlint/plugins",
        "jscodeshift",
        "oxlint-plugin-complexity",
        "oxlint-tsgolint"
      ],
      "ignore": ["test/rules/fixtures/**/*.ts"],
      "entry": [
        "src/index.ts",
        "src/rules/plugin.ts",
        "bench/run-all.ts",
        "bench/rfd-compare.ts",
        "bench/rfd-perf.ts",
        "test/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "bench/**/*.ts", "test/**/*.ts"]
    }
  }
}
