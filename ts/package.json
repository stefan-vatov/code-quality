{
  "name": "@thethracian/oxlint-config",
  "version": "0.3.0",
  "description": "The Thracian Oxlint configuration.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stefan-vatov/code-quality.git",
    "directory": "ts"
  },
  "bin": {
    "thx-codemod-fix": "./dist/codemod-fix/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./codemod-fix": {
      "types": "./dist/codemod-fix/index.d.ts",
      "default": "./dist/codemod-fix/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node ../scripts/add-js-extensions.mjs",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.66.0",
    "jscodeshift": "^17.3.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "devDependencies": {
    "oxlint": "^1.63.0"
  },
  "peerDependencies": {
    "oxlint": ">=1.63.0"
  }
}
