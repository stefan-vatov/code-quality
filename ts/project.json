{
  "name": "ts",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "root": "ts",
  "sourceRoot": "ts/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "pnpm --dir ts build",
      "outputs": ["{projectRoot}/dist"]
    },
    "check": {
      "command": "pnpm --dir ts check"
    },
    "lint": {
      "command": "pnpm exec oxlint ts --type-aware --type-check && pnpm exec oxfmt --check ts '!ts/dist/**'"
    },
    "test": {
      "command": "pnpm exec vitest run --config vitest.config.mts --passWithNoTests ts"
    },
    "pack": {
      "command": "mkdir -p dist/packages && pnpm --dir ts pack --pack-destination ../dist/packages",
      "outputs": ["{workspaceRoot}/dist/packages"]
    }
  }
}
