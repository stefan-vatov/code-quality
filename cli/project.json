{
  "name": "cli",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "root": "cli",
  "sourceRoot": "cli/src",
  "projectType": "application",
  "implicitDependencies": ["rust", "elixir"],
  "targets": {
    "build": {
      "command": "pnpm --dir cli build",
      "outputs": ["{projectRoot}/dist"]
    },
    "check": {
      "command": "pnpm --dir cli check"
    },
    "lint": {
      "command": "pnpm exec oxlint cli --type-aware --type-check && pnpm exec oxfmt --check cli"
    },
    "test": {
      "command": "pnpm exec vitest run --config vitest.config.mts --passWithNoTests cli"
    },
    "pack": {
      "command": "mkdir -p dist/packages && pnpm --dir cli pack --pack-destination ../dist/packages",
      "outputs": ["{workspaceRoot}/dist/packages"]
    }
  }
}
