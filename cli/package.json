{
  "name": "@thethracian/lint-cli",
  "version": "0.0.0",
  "description": "Patcher CLI for The Thracian lint configs.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "thx-lint-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@thethracian/elixir-lint-config": "workspace:*",
    "@thethracian/rust-lint-config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0"
  }
}
